# PostgreSQL connection string for Prisma
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellarherd?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stellarherd?schema=public"

# Stage-suffixed fallbacks used by the runtime resolver when DATABASE_URL is unset.
# The resolver (src/common/prisma-url.ts, mirrored in prisma.config.ts) picks
# DATABASE_URL first; otherwise it falls back to DATABASE_URL_<STAGE> based on
# the upper-cased STAGE (or NODE_ENV), with a STAGING → DATABASE_URL_PROD alias.
DATABASE_URL_DEV="postgresql://postgres:postgres@localhost:5432/stellarherd_dev?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/stellarherd_test?schema=public"
DATABASE_URL_PROD="postgresql://postgres:postgres@localhost:5432/stellarherd_prod?schema=public"

# Selects which stage-suffixed fallback the runtime resolver uses when
# DATABASE_URL is unset. Common values: DEV, TEST, PROD.
# STAGE=STAGING also falls back to DATABASE_URL_PROD.
STAGE=DEV
